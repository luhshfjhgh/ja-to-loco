# Configuração do Supabase (Lovable Cloud gerencia automaticamente)
VITE_SUPABASE_URL="https://seu-projeto.supabase.co"
VITE_SUPABASE_ANON_KEY="sua-anon-key"

# ============ EmailJS ============
# Crie sua conta em https://www.emailjs.com/
# Um único template cobre verificação, reset de senha, boas-vindas e alerta.
# Configure no template do EmailJS as variáveis: to_email, to_name, code, subject, message

VITE_EMAILJS_PUBLIC_KEY="sua_public_key"
VITE_EMAILJS_SERVICE_ID="service_xxxx"
VITE_EMAILJS_TEMPLATE_ID="template_xxxx"
